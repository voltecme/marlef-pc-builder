<odoo>
    <data noupdate="1">
        <!-- Cron for Venus.tech Stock Sync -->
        <record id="ir_cron_sync_venus_stock" model="ir.cron">
            <field name="name">Venus.tech: Stock Synchronization</field>
            <field name="model_id" ref="model_product_template"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_venus_tech_stock()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
        </record>

        <!-- Sample Motherboards -->
        <record id="product_mb_1" model="product.template">
            <field name="name">ASUS ROG Strix Z790-E</field>
            <field name="is_pc_component" eval="True"/>
            <field name="component_type">motherboard</field>
            <field name="socket_type">LGA1700</field>
            <field name="ram_type">ddr5</field>
            <field name="list_price">499.99</field>
            <field name="website_published" eval="True"/>
        </record>

        <!-- Sample CPUs -->
        <record id="product_cpu_1" model="product.template">
            <field name="name">Intel Core i9-13900K</field>
            <field name="is_pc_component" eval="True"/>
            <field name="component_type">cpu</field>
            <field name="socket_type">LGA1700</field>
            <field name="list_price">589.99</field>
            <field name="website_published" eval="True"/>
        </record>

        <!-- Sample RAM -->
        <record id="product_ram_1" model="product.template">
            <field name="name">Corsair Vengeance 32GB DDR5</field>
            <field name="is_pc_component" eval="True"/>
            <field name="component_type">ram</field>
            <field name="ram_type">ddr5</field>
            <field name="list_price">159.99</field>
            <field name="website_published" eval="True"/>
        </record>
    </data>
</odoo>

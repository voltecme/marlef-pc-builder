<odoo>
    <!-- Product Template Inherit Form View -->
    <record id="product_template_form_view_inherit_pc_builder" model="ir.ui.view">
        <field name="name">product.template.form.inherit.pc.builder</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <page name="sales" position="after">
                <page string="PC Builder" name="pc_builder">
                    <group>
                        <group string="Configuration">
                            <field name="is_pc_component"/>
                            <field name="component_type" invisible="not is_pc_component"/>
                        </group>
                        <group string="Compatibility" invisible="not is_pc_component">
                            <field name="socket_type" invisible="component_type not in ['motherboard', 'cpu']"/>
                            <field name="ram_type" invisible="component_type not in ['motherboard', 'ram']"/>
                        </group>
                        <group string="3D Visualization" invisible="not is_pc_component">
                            <field name="three_d_model_url"/>
                            <field name="png_no_background" widget="image"/>
                        </group>
                    </group>
                </page>
            </page>
        </field>
    </record>

    <!-- PC Build Tree View -->
    <record id="view_pc_build_tree" model="ir.ui.view">
        <field name="name">pc.build.tree</field>
        <field name="model">pc.build</field>
        <field name="arch" type="xml">
            <tree string="PC Builds">
                <field name="name"/>
                <field name="user_id"/>
                <field name="total_price"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <!-- PC Build Form View -->
    <record id="view_pc_build_form" model="ir.ui.view">
        <field name="name">pc.build.form</field>
        <field name="model">pc.build</field>
        <field name="arch" type="xml">
            <form string="PC Build">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="session_id"/>
                        </group>
                        <group>
                            <field name="total_price" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Components">
                            <group>
                                <field name="motherboard_id"/>
                                <field name="cpu_id"/>
                                <field name="ram_id"/>
                                <field name="storage_id"/>
                                <field name="gpu_id"/>
                                <field name="case_id"/>
                                <field name="psu_id"/>
                                <field name="cooler_id"/>
                                <field name="fan_id"/>
                                <field name="controller_id"/>
                                <field name="cable_id"/>
                                <field name="assembly_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- PC Build Action -->
    <record id="action_pc_build" model="ir.actions.act_window">
        <field name="name">PC Builds</field>
        <field name="res_model">pc.build</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

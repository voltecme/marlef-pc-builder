<odoo>
    <record id="res_config_settings_view_form_pc_builder" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pc.builder</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='website_settings']" position="after">
                <h2>Marlef PC Builder</h2>
                <div class="row mt16 o_settings_container" id="pc_builder_settings">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">Venus.tech Integration</span>
                            <div class="text-muted">
                                Configure stock synchronization with Venus.tech
                            </div>
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="venus_tech_api_url" class="col-lg-3 o_light_label"/>
                                    <field name="venus_tech_api_url"/>
                                </div>
                                <div class="row mt16">
                                    <label for="venus_tech_api_key" class="col-lg-3 o_light_label"/>
                                    <field name="venus_tech_api_key" password="True"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane"/>
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">AI 3D Visualization</span>
                            <div class="text-muted">
                                API for converting PNG to 3D models
                            </div>
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="ai_3d_generator_api_key" class="col-lg-3 o_light_label"/>
                                    <field name="ai_3d_generator_api_key" password="True"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
